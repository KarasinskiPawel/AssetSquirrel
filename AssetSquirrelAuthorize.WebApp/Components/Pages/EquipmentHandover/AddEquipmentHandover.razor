@page "/addequipmenthandover"
@using AssetSquirrel.CoreBusiness
@using AssetSquirrel.CoreBusiness.Dto
@using AssetSquirrel.UseCases.EquipmentHandover.Interfaces
@using AssetsSquirrel.CoreBusiness
@using Microsoft.AspNetCore.Identity
@using System.Security.Claims

@inject NavigationManager Navigation
@inject IAddEquipmentHandoverUseCase AddEquipmentHandoverUseCase
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthenticationStateProvider

@rendermode InteractiveServer

<div class="row col-12">
    <p class="text-center fw-bold">Equipment Handover Form</p>
</div>

@if (employees is not null && locations is not null && availableEquipment is not null)
{
    <EditForm FormName="AddEquipmentHandover"
              EditContext="EditContext">
        <DataAnnotationsValidator></DataAnnotationsValidator>

        <div class="row col-6">
            <div class="row">
                <div class="col-4">
                    <label class="col-form-label"> Handover to (location) </label>
                </div>
                <div class="col-8">
                    <InputSelect class="form-control" @bind-Value="equipmentHandover.ToLocationId">
                        <option value=""> ...location... </option>
                        @foreach (var location in locations)
                        {
                            <option value="@location.LocationId">@location.City @location.Street</option>
                        }
                    </InputSelect>
                </div>
            </div>
        </div>
        <div class="row col-6 mt-3">
            <div class="row">
                <div class="col-4">
                    <label class="col-form-label"> Handover for (employee) </label>
                </div>
                <div class="col-8">
                    <InputSelect class="form-control" @bind-Value="equipmentHandover.ToEmployeeId">
                        <option value=""> ...employee... </option>
                        @foreach (var employee in employees)
                        {
                            <option value="@employee.EmployeeId">@employee.LastName @employee.FirstName </option>
                        }
                    </InputSelect>
                </div>
            </div>
        </div>
        <div class="row col-6 mt-3">
            <div class="row">
                <div class="col-4">
                    <label class="col-form-label"> Comment </label>
                </div>
                <div class="col-8">
                    <InputTextArea class="form-control" rows="3" maxlength="500" @bind-Value="equipmentHandover.Comment"></InputTextArea>
                </div>
            </div>
        </div>

        <div class="row col-12 mt-4">
            <div class="col-6">
                <p><b>Dostępny sprzęt:</b></p>

                <div class="row mb-2">
                    <div class="col-3">
                        <input class="form-control form-control-sm" placeholder="Manufacturer" @bind="filterManufacturer" @bind:event="oninput" />
                    </div>
                    <div class="col-3">
                        <input class="form-control form-control-sm" placeholder="Hardware type" @bind="filterHardwareType" @bind:event="oninput" />
                    </div>
                    <div class="col-3">
                        <input class="form-control form-control-sm" placeholder="Model" @bind="filterModel" @bind:event="oninput" />
                    </div>
                    <div class="col-3">
                        <input class="form-control form-control-sm" placeholder="Serial number" @bind="filterSerialNumber" @bind:event="oninput" />
                    </div>
                </div>

                <table id="table-color" class="table table-bordered">
                    <thead>
                        <tr class="text-center">
                            <th scope="col">Manufacturer</th>
                            <th scope="col">Hardware type</th>
                            <th scope="col">Model</th>
                            <th scope="col">Serial number</th>
                            <th scope="col"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var equipment in FilteredAvailableEquipment())
                        {
                            <tr>
                                <td>@equipment.ManufacturerName</td>
                                <td>@equipment.HardwareTypeName</td>
                                <td>@equipment.ModelName</td>
                                <td>@equipment.SerialNumber</td>
                                <td>
                                    <button type="button" class="btn btn-sm btn-outline-success" @onclick="(() => AddItem(equipment.EquipmentId))">
                                        <i class="bi bi-plus-circle"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="col-6">
                <p><b>Pozycje do przekazania:</b></p>

                <div class="row mb-2">
                    <div class="col-12">
                        <input class="form-control form-control-sm" placeholder="Filtruj wybrane pozycje" @bind="filterSelectedItems" @bind:event="oninput" />
                    </div>
                </div>

                <table id="table-color" class="table table-bordered">
                    <thead>
                        <tr class="text-center">
                            <th scope="col">Manufacturer</th>
                            <th scope="col">Hardware type</th>
                            <th scope="col">Model</th>
                            <th scope="col">Serial number</th>
                            <th scope="col"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (selectedEquipmentIds.Count == 0)
                        {
                            <tr>
                                <td colspan="5" class="text-muted text-center">Brak dodanych pozycji.</td>
                            </tr>
                        }
                        else if (!FilteredSelectedEquipment().Any())
                        {
                            <tr>
                                <td colspan="5" class="text-muted text-center">Brak pozycji spełniających filtr.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var equipment in FilteredSelectedEquipment())
                            {
                                <tr>
                                    <td>@equipment.ManufacturerName</td>
                                    <td>@equipment.HardwareTypeName</td>
                                    <td>@equipment.ModelName</td>
                                    <td>@equipment.SerialNumber</td>
                                    <td>
                                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="(() => RemoveItem(equipment.EquipmentId))">
                                            <i class="bi bi-dash-circle"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="row col-12 mt-3">
            <div class="col-12">
                <button type="button" class="btn btn-sm btn-primary" @onclick="Save"> Zapisz </button>
            </div>
        </div>

    </EditForm>
}

@code {
    List<EmployeeDto>? employees;
    List<LocationDto>? locations;
    List<EquipmentDto>? availableEquipment;

    List<int> selectedEquipmentIds = new();

    string filterManufacturer = string.Empty;
    string filterHardwareType = string.Empty;
    string filterModel = string.Empty;
    string filterSerialNumber = string.Empty;
    string filterSelectedItems = string.Empty;

    private EditContext? EditContext;

    EquipmentHandoverDto equipmentHandover = new EquipmentHandoverDto
    {
        Comment = string.Empty,
        HandoverDate = DateTime.Now
    };

    protected override async Task OnInitializedAsync()
    {
        employees = await AddEquipmentHandoverUseCase.GetEmployeesAsync(a => a.IsActive == true);
        locations = await AddEquipmentHandoverUseCase.GetLocationsAsync(a => a.IsActive == true);
        availableEquipment = await AddEquipmentHandoverUseCase.GetEquipmentAsync(a => a.IsActive == true);

        EditContext = new EditContext(equipmentHandover);
    }

    private IEnumerable<EquipmentDto> FilteredAvailableEquipment()
    {
        return availableEquipment
            .Where(e => !selectedEquipmentIds.Contains(e.EquipmentId))
            .Where(e => string.IsNullOrWhiteSpace(filterManufacturer) || (e.ManufacturerName?.Contains(filterManufacturer, StringComparison.OrdinalIgnoreCase) ?? false))
            .Where(e => string.IsNullOrWhiteSpace(filterHardwareType) || (e.HardwareTypeName?.Contains(filterHardwareType, StringComparison.OrdinalIgnoreCase) ?? false))
            .Where(e => string.IsNullOrWhiteSpace(filterModel) || (e.ModelName?.Contains(filterModel, StringComparison.OrdinalIgnoreCase) ?? false))
            .Where(e => string.IsNullOrWhiteSpace(filterSerialNumber) || (e.SerialNumber?.Contains(filterSerialNumber, StringComparison.OrdinalIgnoreCase) ?? false));
    }

    private IEnumerable<EquipmentDto> FilteredSelectedEquipment()
    {
        return availableEquipment
            .Where(e => selectedEquipmentIds.Contains(e.EquipmentId))
            .Where(e => string.IsNullOrWhiteSpace(filterSelectedItems) ||
                (e.ManufacturerName?.Contains(filterSelectedItems, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (e.HardwareTypeName?.Contains(filterSelectedItems, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (e.ModelName?.Contains(filterSelectedItems, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (e.SerialNumber?.Contains(filterSelectedItems, StringComparison.OrdinalIgnoreCase) ?? false));
    }

    private void AddItem(int equipmentId)
    {
        if (!selectedEquipmentIds.Contains(equipmentId))
        {
            selectedEquipmentIds.Add(equipmentId);
        }
    }

    private void RemoveItem(int equipmentId)
    {
        selectedEquipmentIds.Remove(equipmentId);
    }

    private async Task Save()
    {
        if (equipmentHandover.ToLocationId is null && equipmentHandover.ToEmployeeId is null)
        {
            await JSRuntime.InvokeVoidAsync("OperationAborted", "Please select a location and/or an employee.");
            return;
        }

        if (selectedEquipmentIds.Count == 0)
        {
            await JSRuntime.InvokeVoidAsync("OperationAborted", "Please add at least one equipment item.");
            return;
        }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        var result = await AddEquipmentHandoverUseCase.SaveHandoverAsync(equipmentHandover, selectedEquipmentIds, userId);

        if (result.Success)
        {
            await JSRuntime.InvokeVoidAsync("OperationSuccessful", "Equipment handover has been saved.");
            Navigation.NavigateTo("/equipmenthandover");
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("OperationAborted", result.Message ?? "Saving error.");
        }
    }
}
