@page "/equipmenthandover"
@using AssetSquirrel.CoreBusiness
@using AssetSquirrel.CoreBusiness.Dto
@using AssetSquirrel.UseCases.EquipmentHandover.Interfaces
@using System.Security.Claims

@inject NavigationManager Navigation
@inject IViewEquipmentHandoverUseCase ViewEquipmentHandover
@inject IEditEquipmentHandoverUseCase EditEquipmentHandoverUseCase
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthenticationStateProvider

@rendermode InteractiveServer

<div class="row col-12">
    <div class="d-flex align-items-center gap-2">
        <AdminOnly>
            <button class="btn btn-sm btn-outline-dark" style="width: 10rem; margin: 0.5rem;" @onclick="(() => RedirectToAddEquipmentHandover())">
                <i class="bi bi-feather"></i>
                Handover
            </button>
        </AdminOnly>

        <TextSearchBar placeholderText="Document number"
                       TextSearchBarCallback="SearchCallback">
        </TextSearchBar>

        <TextSearchBar placeholderText="Employee name"
                       TextSearchBarCallback="SearchEmployeeCallback">
        </TextSearchBar>
    </div>
</div>

@if (isLoading)
{
    <LoadingSpinner />
}
else
{
<div class="row col-12 mt-3">
    <div id="table-container">
        <table id="table-color" class="table table-bordered">
            <thead>
                <tr class="text-center">
                    <th scope="col"> Lp. </th>
                    <th scope="col"> Document number </th>
                    <th scope="col"> Handover date </th>
                    <th scope="col"> To </th>
                    <th scope="col"> Prepared by </th>
                    <th scope="col"> Posted </th>
                    <th scope="col"> Active </th>
                    <th scope="col">
                        <i class="bi bi-gear"></i>
                    </th>
                </tr>
            </thead>
            <tbody>
                @if (handovers is not null && handovers.Count() > 0)
                {
                    @foreach (var handover in handovers)
                    {
                        <tr>
                            <td> @(handovers.IndexOf(handover) + 1) </td>
                            <td> @handover.HandoverDocumentNumber </td>
                            <td> @handover.HandoverDate.ToShortDateString() </td>
                            <td> @Recipient(handover) </td>
                            <td> @handover.PreparedByUserName </td>
                            <td>
                                @if (handover.IsPosted)
                                {
                                    <i class="bi bi-check-circle form-control as-bg-green"></i>
                                }
                                else
                                {
                                    <i class="bi bi-hourglass-split form-control"></i>
                                }
                            </td>
                            <td>
                                @if (handover.IsActive)
                                {
                                    <i class="bi bi-shield-check form-control as-bg-green"></i>
                                }
                                else
                                {
                                    <i class="bi bi-shield-x form-control as-bg-red"></i>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-2">
                                    <button class="btn btn-sm btn-outline-primary" title="Print / view PDF" @onclick="(() => PrintHandover(handover))">
                                        <i class="bi bi-file-earmark-pdf"></i>
                                    </button>

                                    <button class="btn btn-sm btn-outline-info" title="View items" @onclick="(() => ShowModalViewItems(handover))">
                                        <i class="bi bi-list-ul"></i>
                                    </button>

                                    <AdminOnly>
                                        <button class="btn btn-sm btn-outline-warning" title="Attach / replace signed document" @onclick="(() => ShowModalAddDocument(handover))">
                                            <i class="bi bi-file-arrow-up"></i>
                                        </button>
                                    </AdminOnly>

                                    @if (handover.FilePath is not null)
                                    {
                                        <button class="btn btn-sm btn-outline-success" title="Download attached document" @onclick="(() => DownloadDocument(handover))">
                                            <i class="bi bi-file-arrow-down"></i>
                                        </button>
                                    }

                                    @if (handover.IsActive)
                                    {
                                        <AdminOnly>
                                            <button class="btn btn-sm btn-outline-danger" title="Cancel" @onclick="(() => CancelHandover(handover))">
                                                <i class="bi bi-x-circle"></i>
                                            </button>
                                        </AdminOnly>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
}

<DialogBox Show="modalAddDocument"
           Title="Attach signed document">
    <EquipmentHandoverAddDocumentDialogBox
        OnCancel="OnCancelHideModalAddDocument"
        OnSave="OnSaveHideModalAddDocument"
        Handover="selectedHandover" />
</DialogBox>

<DialogBox Show="modalViewItems"
           Title="Handover items">
    <EquipmentHandoverItemsDialogBox
        Handover="selectedHandoverForItems"
        OnClose="OnCloseModalViewItems" />
</DialogBox>

@code {
    bool modalAddDocument = false;
    bool modalViewItems = false;

    List<EquipmentHandoverDto>? handovers;
    EquipmentHandoverDto? selectedHandover;
    EquipmentHandoverDto? selectedHandoverForItems;
    string searchText = string.Empty;
    string employeeSearchText = string.Empty;
    bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        handovers = await ViewEquipmentHandover.GetEquipmentHandoverAsync(a => true);
        isLoading = false;
    }

    private void RedirectToAddEquipmentHandover()
    {
        Navigation.NavigateTo("/addequipmenthandover");
    }

    private async Task SearchCallback(string text)
    {
        searchText = text;
        await SearchHandovers();
    }

    private async Task SearchEmployeeCallback(string text)
    {
        employeeSearchText = text;
        await SearchHandovers();
    }

    private async Task SearchHandovers()
    {
        var docText = searchText ?? string.Empty;
        var empText = employeeSearchText ?? string.Empty;

        handovers = await ViewEquipmentHandover.GetEquipmentHandoverAsync(h =>
            (string.IsNullOrEmpty(docText) || h.HandoverDocumentNumber.Contains(docText)) &&
            (string.IsNullOrEmpty(empText) || (h.ToEmployee != null && (h.ToEmployee.FirstName.Contains(empText) || h.ToEmployee.LastName.Contains(empText)))));

        StateHasChanged();
    }

    private static string Recipient(EquipmentHandoverDto handover)
    {
        var parts = new List<string>();
        if (handover.ToEmployee is not null)
        {
            parts.Add($"{handover.ToEmployee.FirstName} {handover.ToEmployee.LastName}");
        }
        if (handover.ToLocation is not null)
        {
            parts.Add($"{handover.ToLocation.City} {handover.ToLocation.Street}");
        }
        return parts.Count > 0 ? string.Join(" / ", parts) : "-";
    }

    private async Task PrintHandover(EquipmentHandoverDto handover)
    {
        await JSRuntime.InvokeVoidAsync("openInNewTab", $"/api/equipmenthandover/{handover.EquipmentHandoverId}/pdf");
    }

    private void ShowModalAddDocument(EquipmentHandoverDto handover)
    {
        selectedHandover = handover;
        modalAddDocument = true;
    }

    private void ShowModalViewItems(EquipmentHandoverDto handover)
    {
        selectedHandoverForItems = handover;
        modalViewItems = true;
    }

    private void OnCloseModalViewItems()
    {
        modalViewItems = false;
    }

    private void OnCancelHideModalAddDocument()
    {
        modalAddDocument = false;
    }

    private async Task OnSaveHideModalAddDocument(Result<EquipmentHandoverDto> result)
    {
        await result.ShowToastAsync(JSRuntime, "Document has been attached.", "Błąd operacji");

        if (result.Success)
        {
            await SearchHandovers();
        }

        modalAddDocument = false;
    }

    private async Task DownloadDocument(EquipmentHandoverDto handover)
    {
        if (handover.FilePath is not null)
        {
            await JSRuntime.InvokeVoidAsync("openInNewTab", handover.FilePath);
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("OperationAborted", "Document unavailable.");
        }
    }

    private async Task CancelHandover(EquipmentHandoverDto handover)
    {
        if (!await AdminGuard.IsAdminAsync(AuthenticationStateProvider)) return;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        var result = await EditEquipmentHandoverUseCase.CancelEquipmentHandoverAsync(handover.EquipmentHandoverId, userId);
        await result.ShowToastAsync(JSRuntime, "Equipment handover has been cancelled.", "Błąd operacji");

        if (result.Success)
        {
            await SearchHandovers();
        }
    }
}
