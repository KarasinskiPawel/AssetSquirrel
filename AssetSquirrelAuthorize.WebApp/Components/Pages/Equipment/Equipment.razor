@page "/equipment"
@using AssetSquirrel.CoreBusiness
@using AssetSquirrel.CoreBusiness.Dto
@using AssetSquirrel.UseCases.EquipmentUseCase.Interfaces
@using AssetSquirrel.UseCases.Suppilers.Interfaces
@using AssetSquirrel.UseCases.Manufacturers.Interfaces
@using AssetSquirrel.UseCases.HardwareType.Interfaces
@using AssetSquirrelAuthorize.WebApp.Components.ViewModels
@using AssetsSquirrel.CoreBusiness
@using Microsoft.AspNetCore.Identity
@using System.Security.Claims

@inject IJSRuntime JSRuntime
@inject IViewEquipmentUseCase ViewEquipmentUseCase
@inject IViewSuppilersUseCase ViewSuppilersUseCase
@inject IViewManufacturerUseCase ViewManufacturerUseCase
@inject IViewHardwareTypeUseCase ViewHardwareTypeUseCase
@inject AuthenticationStateProvider AuthenticationStateProvider

@rendermode InteractiveServer

<div class="col-12">
    <div class="row offset-2 col-8 d-flex align-items-center flex-wrap gap-2">
        <InputSelect class="form-control-sm w-20" @bind-Value="equipmentRequest.SuppilerId" @bind-Value:after="SearchEquipments">
            <option value=""> ...suppiler... </option>
            @if (suppilers is not null)
            {
                @foreach (var suppiler in suppilers)
                {
                    <option value="@suppiler.SuppilerId">@suppiler.Name</option>
                }
            }
        </InputSelect>

        <InputSelect class="form-control-sm w-20" @bind-Value="equipmentRequest.ManufacturerId" @bind-Value:after="SearchEquipments">
            <option value=""> ...manufacturer... </option>
            @if (manufacturers is not null)
            {
                @foreach (var manufacturer in manufacturers)
                {
                    <option value="@manufacturer.ManufacturerId">@manufacturer.Name</option>
                }
            }
        </InputSelect>

        <InputSelect class="form-control-sm w-20" @bind-Value="equipmentRequest.HardwareTypeId" @bind-Value:after="SearchEquipments">
            <option value=""> ...type... </option>
            @if (hardwareTypes is not null)
            {
                @foreach (var hardwareType in hardwareTypes)
                {
                    <option value="@hardwareType.HardwareTypeId">@hardwareType.Name</option>
                }
            }
        </InputSelect>

            <InputSelect class="form-control-sm w-10" @bind-Value="equipmentRequest.IsActive" @bind-Value:after="SearchEquipments">
            <option value="true">Active</option>
            <option value="false">Inactive</option>
        </InputSelect>

        <AdminOnly>
            <button class="btn btn-sm btn-outline-dark" style="width: 10rem; margin: 0.5rem;" @onclick="(() => ShowModalAddEquipment())">
                <i class="bi bi-motherboard"></i>
                Add equipment
            </button>
        </AdminOnly>
    </div>

    <div class="row offset-3 col-5 d-flex align-items-center gap-2 mt-2">
        <TextSearchBar placeholderText="serial number, model, inventory number..."
                       TextSearchBarCallback="SearchCallback"
                       FullWidth="true">
        </TextSearchBar>
    </div>
</div>

@if (isLoading)
{
    <LoadingSpinner />
}
else
{
<div class="row col-12 mt-3">
    <div id="table-container">
        <table id="table-color" class="table table-bordered">
            <thead>
                <tr class="text-center">
                    <th scope="col"> Lp. </th>
                    <th scope="col"> Suppiler name </th>
                    <th scope="col"> Manufacturer name </th>
                    <th scope="col"> Hardware type </th>
                    <th scope="col"> Model name </th>
                    <th scope="col"> Serial &amp; Inventory Nr. </th>
                    <th scope="col"> Invoice number </th>
                    <th scope="col"> Description </th>
                    <th scope="col"> Date add </th>
                    <th scope="col"> Date removed </th>
                    <th scope="col"> Is active? </th>
                    <th scope="col"> Added by </th>
                    <th scope="col">
                        <i class="bi bi-gear"></i>
                    </th>
                </tr>
            </thead>
            <tbody>
                @if (equipments is not null && equipments.Count() > 0)
                {
                    @foreach(var equipment in equipments)
                    {
                        <tr>
                            <td> @(equipments.IndexOf(equipment) + 1) </td>
                            <td> @equipment.SuppilerName </td>
                            <td> @equipment.ManufacturerName </td>
                            <td> @equipment.HardwareTypeName </td>
                            <td> @equipment.ModelName </td>
                            <td> @equipment.SerialNumber <br /> @equipment.InventoryNumber </td>
                            <td> @equipment.InvoiceNumber </td>
                            <td> @equipment.Description </td>
                            <td> @equipment.DateAdd.ToShortDateString() </td>
                            <td> @equipment.DateRemoved?.ToShortDateString() </td>
                            <td>
                                @if(equipment.IsActive)
                                {
                                    <i class="bi bi-shield-check form-control as-bg-green"></i>
                                }
                                else
                                {
                                    <i class="bi bi-shield-x form-control as-bg-red"></i>
                                }
                            </td>
                            <td> @equipment.RegisteredByUserName </td>
                            <td>
                                <AdminOnly>
                                    <button class="btn btn-sm btn-outline-warning" title="Edit" @onclick="(() => ShowModalEditEquipment(equipment))">
                                        <i class="bi bi-pen"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" title="Dezaktywuj sprzęt." @onclick="(() => RemoveEquipment(equipment))">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </AdminOnly>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
}

<DialogBox Show="modalAddEquipment"
Title="Add equipment">
    <EquipmentAddDialogBox
    OnCancel="OnCancelHideModalAddEquipment"
    OnSave="OnSaveHideModalAddEquipment" />
</DialogBox>

<DialogBox Show="modalEditEquipment"
           Title="Edit equipment">
    <EquipmentEditDialogBox
        OnCancel="OnCancelHideModalEditEquipment"
        OnSave="OnSaveHideModalEditEquipment"
        Equipment="equipment" />
</DialogBox>

@code {
    bool modalAddEquipment = false;
    bool modalEditEquipment = false;

    EquipmentRequest equipmentRequest = new EquipmentRequest();

    // string searchText = string.Empty;
    // bool? searchActive = null;

    List<EquipmentDto> equipments { get; set;}
    EquipmentDto equipment;
    bool isLoading = true;

    List<SuppilerDto>? suppilers;
    List<ManufacturerDto>? manufacturers;
    List<HardwareTypeDto>? hardwareTypes;

    protected override async Task OnInitializedAsync()
    {
        equipments = await ViewEquipmentUseCase.GetEquipmentAsync(a => a.IsActive == true);
        suppilers = await ViewSuppilersUseCase.GetSuppilersAsync(s => s.IsActive);
        manufacturers = await ViewManufacturerUseCase.GetManufacturersAsync(m => m.IsActive);
        hardwareTypes = await ViewHardwareTypeUseCase.GetHardwareTypesAsync(h => h.IsActive);
        isLoading = false;
    }

    public void OnCancelHideModalEditEquipment()
    {
        modalEditEquipment = false;
    }

    public async Task OnSaveHideModalEditEquipment(Result<EquipmentDto> result)
    {
        await result.ShowToastAsync(JSRuntime, "Equipment has been edited.", "Błąd aktualizacji");

        if (result.Success)
        {
            await SearchEquipments();
            StateHasChanged();
        }

        modalEditEquipment = false;
    }

    private void ShowModalAddEquipment()
    {
        modalAddEquipment = true;
    }

    private void ShowModalEditEquipment(EquipmentDto equipment)
    {
        this.equipment = equipment;
        modalEditEquipment = true;
    }

    private void OnCancelHideModalAddEquipment()
    {
        modalAddEquipment = false;
    }

    private async Task OnSaveHideModalAddEquipment(Result<EquipmentDto> result)
    {
        await result.ShowToastAsync(JSRuntime, "Equipment has been added.", "Błąd zapisu");

        if (result.Success)
        {
            await SearchEquipments();
            StateHasChanged();
        }

        modalAddEquipment = false;
    }

    private async Task SearchCallback(string searchText)
    {
        this.equipmentRequest.SearchText = searchText;
        await SearchEquipments();
    }

    public async Task SearchEquipments()
    {
        equipments = await ViewEquipmentUseCase.GetEquipmentAsync(
            a => (a.ModelName.Contains(equipmentRequest.SearchText ?? "") ||
            a.SerialNumber.Contains(equipmentRequest.SearchText ?? "") ||
            a.InventoryNumber.Contains(equipmentRequest.SearchText ?? "")) &&
            a.IsActive == equipmentRequest.IsActive &&
            (equipmentRequest.SuppilerId == null || a.SuppilerId == equipmentRequest.SuppilerId) &&
            (equipmentRequest.ManufacturerId == null || a.ManufacturerId == equipmentRequest.ManufacturerId) &&
            (equipmentRequest.HardwareTypeId == null || a.HardwareTypeId == equipmentRequest.HardwareTypeId)
        );

        StateHasChanged();
    }

    public async Task RemoveEquipment(EquipmentDto equipment)
    {
        if (!await AdminGuard.IsAdminAsync(AuthenticationStateProvider)) return;

        // Equipment is never hard-deleted from the database — "remove" means
        // deactivating it (IsActive = false), so history/audit trail is preserved.
        equipment.IsActive = false;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            equipment.RegisteredByUserId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        }

        var result = await ViewEquipmentUseCase.UpdateEquipmentAsync(equipment);
        await result.ShowToastAsync(JSRuntime, "Equipment has been deactivated.", "Błąd operacji");

        if (result.Success)
        {
            await SearchEquipments();
            StateHasChanged();
        }
    }
}
