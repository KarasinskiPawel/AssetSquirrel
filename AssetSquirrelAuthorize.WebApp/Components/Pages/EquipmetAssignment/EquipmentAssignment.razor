@page "/equipmentassignment"
@using AssetSquirrel.CoreBusiness
@using AssetSquirrel.CoreBusiness.Dto
@using AssetSquirrel.UseCases.EquipmentAssignment
@using AssetSquirrel.UseCases.EquipmentAssignment.Interfaces
@using AssetSquirrel.UseCases.Locations.Interfaces
@using AssetSquirrel.UseCases.Employees.Interfaces
@using AssetSquirrel.UseCases.Manufacturers.Interfaces
@using AssetSquirrel.UseCases.HardwareType.Interfaces

@inject IViewEquipmentAssignmentUseCase ViewEquipmentAssignmentUseCase
@inject IViewLocationsUseCase ViewLocationsUseCase
@inject IViewEmployeesUseCase ViewEmployeesUseCase
@inject IViewManufacturerUseCase ViewManufacturerUseCase
@inject IViewHardwareTypeUseCase ViewHardwareTypeUseCase
@inject IJSRuntime JSRuntime

@rendermode InteractiveServer

<div class="row col-12">
    <div class="row offset-2 col-8 d-flex align-items-center flex-wrap gap-2">
        <InputSelect class="form-control-sm w-20" @bind-Value="filter.LocationId" @bind-Value:after="Search">
            <option value=""> ...location... </option>
            @if (locations is not null)
            {
                @foreach (var location in locations)
                {
                    <option value="@location.LocationId">@location.City @location.Street</option>
                }
            }
        </InputSelect>

        <InputSelect class="form-control-sm w-20" @bind-Value="filter.EmployeeId" @bind-Value:after="Search">
            <option value=""> ...employee... </option>
            @if (employees is not null)
            {
                @foreach (var employee in employees)
                {
                    <option value="@employee.EmployeeId">@employee.LastName @employee.FirstName</option>
                }
            }
        </InputSelect>

        <InputSelect class="form-control-sm w-20" @bind-Value="filter.ManufacturerId" @bind-Value:after="Search">
            <option value=""> ...manufacturer... </option>
            @if (manufacturers is not null)
            {
                @foreach (var manufacturer in manufacturers)
                {
                    <option value="@manufacturer.ManufacturerId">@manufacturer.Name</option>
                }
            }
        </InputSelect>

        <InputSelect class="form-control-sm w-20" @bind-Value="filter.HardwareTypeId" @bind-Value:after="Search">
            <option value=""> ...type... </option>
            @if (hardwareTypes is not null)
            {
                @foreach (var hardwareType in hardwareTypes)
                {
                    <option value="@hardwareType.HardwareTypeId">@hardwareType.Name</option>
                }
            }
        </InputSelect>

        <InputSelect class="form-control-sm w-10" @bind-Value="filter.IsActive" @bind-Value:after="Search">
            <option value="true">Active</option>
            <option value="false">Inactive</option>
        </InputSelect>
    </div>

    <div class="row d-flex align-items-center flex-nowrap gap-2 mt-2 offset-3 col-6">
        <div class="offset-2 col-5">
            <TextSearchBar placeholderText="serial number, inventory number, invoice number..."
                        TextSearchBarCallback="SearchCallback"
                        FullWidth="true">
            </TextSearchBar>
        </div>
        <div class=col-1>
            <button class="btn btn-sm btn-outline-info text-nowrap" @onclick="ExportToExcel" title="Export to Excel">
                <i class="bi bi-file-earmark-excel"></i>
                Export
            </button>
        </div>
    </div>
</div>

@if (isLoading)
{
    <LoadingSpinner />
}
else
{
<div class="row col-12 mt-3">
    <div id="table-container">
        <table id="table-color" class="table table-bordered">
            <thead>
                <tr class="text-center">
                    <th scope="col"> Lp. </th>
                    <th scope="col" role="button" @onclick="(() => SortBy(nameof(EquipmentAssignmentOverviewDto.AssignedLocationName)))">
                        Location <i class="bi @SortIcon(nameof(EquipmentAssignmentOverviewDto.AssignedLocationName))"></i>
                    </th>
                    <th scope="col" role="button" @onclick="(() => SortBy(nameof(EquipmentAssignmentOverviewDto.AssignedEmployeeName)))">
                        Person <i class="bi @SortIcon(nameof(EquipmentAssignmentOverviewDto.AssignedEmployeeName))"></i>
                    </th>
                    <th scope="col"> Handover date </th>
                    <th scope="col"> Suppiler </th>
                    <th scope="col"> Manufacturer </th>
                    <th scope="col"> Type </th>
                    <th scope="col"> Model </th>
                    <th scope="col"> Serial &amp; Inventory Nr. </th>
                    <th scope="col"> Invoice number </th>
                    <th scope="col"> Status </th>
                </tr>
            </thead>
            <tbody>
                <Virtualize @ref="assignmentVirtualize" ItemsProvider="LoadAssignmentsAsync" Context="row">
                    <ItemContent>
                        <tr>
                            <td> @row.Position </td>
                            <td> @row.Item.AssignedLocationName </td>
                            <td> @row.Item.AssignedEmployeeName </td>
                            <td> @row.Item.DateOfHandover?.ToShortDateString() </td>
                            <td> @row.Item.SuppilerName </td>
                            <td> @row.Item.ManufacturerName </td>
                            <td> @row.Item.HardwareTypeName </td>
                            <td> @row.Item.ModelName </td>
                            <td> @row.Item.SerialNumber <br /> @row.Item.InventoryNumber </td>
                            <td> @row.Item.InvoiceNumber </td>
                            <td>
                                @if (row.Item.IsAssigned)
                                {
                                    <span class="badge as-bg-green">Assigned</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Available</span>
                                }
                            </td>
                        </tr>
                    </ItemContent>
                    <Placeholder>
                        <tr>
                            <td colspan="10" class="text-center text-muted">Ładowanie...</td>
                        </tr>
                    </Placeholder>
                </Virtualize>
                @if (totalCount == 0)
                {
                    <tr>
                        <td colspan="10" class="text-muted text-center">No equipment matches the current filters.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
}

@code {
    EquipmentAssignmentFilter filter = new EquipmentAssignmentFilter();

    List<LocationDto>? locations;
    List<EmployeeDto>? employees;
    List<ManufacturerDto>? manufacturers;
    List<HardwareTypeDto>? hardwareTypes;

    string? sortColumn;
    bool sortDescending;
    bool isLoading = true;
    int totalCount;

    Virtualize<AssignmentRow>? assignmentVirtualize;

    record AssignmentRow(int Position, EquipmentAssignmentOverviewDto Item);

    protected override async Task OnInitializedAsync()
    {
        locations = await ViewLocationsUseCase.GetLocationsAsync(l => l.IsActive);
        employees = await ViewEmployeesUseCase.GetEmployeesAsync(e => e.IsActive);
        manufacturers = await ViewManufacturerUseCase.GetManufacturersAsync(m => m.IsActive);
        hardwareTypes = await ViewHardwareTypeUseCase.GetHardwareTypesAsync(h => h.IsActive);
        totalCount = await ViewEquipmentAssignmentUseCase.GetEquipmentAssignmentOverviewCountAsync(filter);

        isLoading = false;
    }

    private async Task SearchCallback(string searchText)
    {
        filter.SearchText = searchText;
        await Search();
    }

    private async Task Search()
    {
        totalCount = await ViewEquipmentAssignmentUseCase.GetEquipmentAssignmentOverviewCountAsync(filter);

        if (assignmentVirtualize is not null)
        {
            await assignmentVirtualize.RefreshDataAsync();
        }

        StateHasChanged();
    }

    private async Task ExportToExcel()
    {
        await JSRuntime.InvokeVoidAsync("Information", "Przygotowywanie pliku...");

        var query = new List<string> { $"isActive={filter.IsActive}" };
        if (filter.LocationId is not null) query.Add($"locationId={filter.LocationId}");
        if (filter.EmployeeId is not null) query.Add($"employeeId={filter.EmployeeId}");
        if (filter.ManufacturerId is not null) query.Add($"manufacturerId={filter.ManufacturerId}");
        if (filter.HardwareTypeId is not null) query.Add($"hardwareTypeId={filter.HardwareTypeId}");
        if (!string.IsNullOrEmpty(filter.SearchText)) query.Add($"searchText={Uri.EscapeDataString(filter.SearchText)}");

        await JSRuntime.InvokeVoidAsync("openInNewTab", $"/api/equipmentassignment/export?{string.Join("&", query)}");
    }

    private async ValueTask<ItemsProviderResult<AssignmentRow>> LoadAssignmentsAsync(ItemsProviderRequest request)
    {
        var count = Math.Max(request.Count, 200);
        var items = await ViewEquipmentAssignmentUseCase.GetEquipmentAssignmentOverviewPageAsync(filter, request.StartIndex, count, sortColumn, sortDescending, request.CancellationToken);

        var rows = items
            .Select((dto, i) => new AssignmentRow(request.StartIndex + i + 1, dto))
            .ToList();

        return new ItemsProviderResult<AssignmentRow>(rows, totalCount);
    }

    private async Task SortBy(string column)
    {
        if (sortColumn == column)
        {
            sortDescending = !sortDescending;
        }
        else
        {
            sortColumn = column;
            sortDescending = false;
        }

        await Search();
    }

    private string SortIcon(string column)
    {
        if (sortColumn != column)
        {
            return "bi-arrow-down-up text-muted";
        }

        return sortDescending ? "bi-sort-alpha-down-alt" : "bi-sort-alpha-down";
    }
}
