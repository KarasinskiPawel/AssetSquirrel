@page "/equipmentreturn"
@using AssetSquirrel.CoreBusiness
@using AssetSquirrel.CoreBusiness.Dto
@using AssetSquirrel.UseCases.EquipmentReturn.Interfaces

@inject NavigationManager Navigation
@inject IViewEquipmentReturnUseCase ViewEquipmentReturn
@inject IJSRuntime JSRuntime

@rendermode InteractiveServer

<div class="row col-12">
    <div class="d-flex align-items-center gap-2">
        <button class="btn btn-sm btn-outline-dark" style="width: 10rem; margin: 0.5rem;" @onclick="(() => RedirectToAddEquipmentReturn())">
            <i class="bi bi-arrow-return-left"></i>
            Register return
        </button>

        <TextSearchBar placeholderText="Document number"
                       TextSearchBarCallback="SearchCallback">
        </TextSearchBar>

        <TextSearchBar placeholderText="Employee name"
                       TextSearchBarCallback="SearchEmployeeCallback">
        </TextSearchBar>
    </div>
</div>

<div class="row col-12 mt-3">
    <div id="table-container">
        <table id="table-color" class="table table-bordered">
            <thead>
                <tr class="text-center">
                    <th scope="col"> Lp. </th>
                    <th scope="col"> Document number </th>
                    <th scope="col"> Return date </th>
                    <th scope="col"> From </th>
                    <th scope="col"> Storage location </th>
                    <th scope="col"> Prepared by </th>
                    <th scope="col">
                        <i class="bi bi-gear"></i>
                    </th>
                </tr>
            </thead>
            <tbody>
                @if (returns is not null && returns.Count() > 0)
                {
                    @foreach (var equipmentReturn in returns)
                    {
                        <tr>
                            <td> @(returns.IndexOf(equipmentReturn) + 1) </td>
                            <td> @equipmentReturn.ReturnDocumentNumber </td>
                            <td> @equipmentReturn.ReturnDate.ToShortDateString() </td>
                            <td> @From(equipmentReturn) </td>
                            <td> @equipmentReturn.StorageLocationName </td>
                            <td> @equipmentReturn.PreparedByUserName </td>
                            <td>
                                <div class="d-flex gap-2">
                                    <button class="btn btn-sm btn-outline-primary" title="Print / view PDF" @onclick="(() => PrintReturn(equipmentReturn))">
                                        <i class="bi bi-file-earmark-pdf"></i>
                                    </button>

                                    <button class="btn btn-sm btn-outline-info" title="View items" @onclick="(() => ShowModalViewItems(equipmentReturn))">
                                        <i class="bi bi-list-ul"></i>
                                    </button>

                                    <button class="btn btn-sm btn-outline-warning" title="Attach / replace signed document" @onclick="(() => ShowModalAddDocument(equipmentReturn))">
                                        <i class="bi bi-file-arrow-up"></i>
                                    </button>

                                    @if (equipmentReturn.FilePath is not null)
                                    {
                                        <button class="btn btn-sm btn-outline-success" title="Download attached document" @onclick="(() => DownloadDocument(equipmentReturn))">
                                            <i class="bi bi-file-arrow-down"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<DialogBox Show="modalAddDocument"
           Title="Attach signed document">
    <EquipmentReturnAddDocumentDialogBox
        OnCancel="OnCancelHideModalAddDocument"
        OnSave="OnSaveHideModalAddDocument"
        EquipmentReturn="selectedReturnForDocument" />
</DialogBox>

<DialogBox Show="modalViewItems"
           Title="Returned items">
    <EquipmentReturnItemsDialogBox
        EquipmentReturn="selectedReturnForItems"
        OnClose="OnCloseModalViewItems" />
</DialogBox>

@code {
    bool modalAddDocument = false;
    bool modalViewItems = false;

    List<EquipmentReturnDto>? returns;
    EquipmentReturnDto? selectedReturnForDocument;
    EquipmentReturnDto? selectedReturnForItems;
    string searchText = string.Empty;
    string employeeSearchText = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        returns = await ViewEquipmentReturn.GetEquipmentReturnsAsync(a => true);
    }

    private void RedirectToAddEquipmentReturn()
    {
        Navigation.NavigateTo("/addequipmentreturn");
    }

    private async Task SearchCallback(string text)
    {
        searchText = text;
        await SearchReturns();
    }

    private async Task SearchEmployeeCallback(string text)
    {
        employeeSearchText = text;
        await SearchReturns();
    }

    private async Task SearchReturns()
    {
        var docText = searchText ?? string.Empty;
        var empText = employeeSearchText ?? string.Empty;

        returns = await ViewEquipmentReturn.GetEquipmentReturnsAsync(r =>
            (string.IsNullOrEmpty(docText) || r.ReturnDocumentNumber.Contains(docText)) &&
            (string.IsNullOrEmpty(empText) || (r.Employee != null && (r.Employee.FirstName.Contains(empText) || r.Employee.LastName.Contains(empText)))));

        StateHasChanged();
    }

    private static string From(EquipmentReturnDto equipmentReturn)
    {
        var parts = new List<string>();
        if (equipmentReturn.Employee is not null)
        {
            parts.Add($"{equipmentReturn.Employee.FirstName} {equipmentReturn.Employee.LastName}");
        }
        if (equipmentReturn.Location is not null)
        {
            parts.Add($"{equipmentReturn.Location.City} {equipmentReturn.Location.Street}");
        }
        return parts.Count > 0 ? string.Join(" / ", parts) : "-";
    }

    private async Task PrintReturn(EquipmentReturnDto equipmentReturn)
    {
        await JSRuntime.InvokeVoidAsync("openInNewTab", $"/api/equipmentreturn/{equipmentReturn.EquipmentReturnId}/pdf");
    }

    private void ShowModalAddDocument(EquipmentReturnDto equipmentReturn)
    {
        selectedReturnForDocument = equipmentReturn;
        modalAddDocument = true;
    }

    private void ShowModalViewItems(EquipmentReturnDto equipmentReturn)
    {
        selectedReturnForItems = equipmentReturn;
        modalViewItems = true;
    }

    private void OnCloseModalViewItems()
    {
        modalViewItems = false;
    }

    private void OnCancelHideModalAddDocument()
    {
        modalAddDocument = false;
    }

    private async Task OnSaveHideModalAddDocument(Result<EquipmentReturnDto> result)
    {
        if (result.Success)
        {
            await JSRuntime.InvokeVoidAsync("OperationSuccessful", "Document has been attached.");
            await SearchReturns();
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("OperationAborted", result.Message ?? "Saving error.");
        }

        modalAddDocument = false;
    }

    private async Task DownloadDocument(EquipmentReturnDto equipmentReturn)
    {
        if (equipmentReturn.FilePath is not null)
        {
            await JSRuntime.InvokeVoidAsync("openInNewTab", equipmentReturn.FilePath);
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("OperationAborted", "Document unavailable.");
        }
    }
}
